<Window x:Class="CurrentlyListening.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="420" Height="260"
        MinWidth="380" MinHeight="250"
        MaxWidth="600" MaxHeight="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="20,20,20,0">

        <TextBlock Text="Settings"
                   FontWeight="Bold"
                   FontSize="14"
                   Margin="0,0,0,12"/>

        <CheckBox x:Name="CloseShouldMinimize"
                  Content="Close window should minimize the app"
                  Margin="0,0,0,16"
                  Click="CloseShouldMinimize_OnClick"/>
        
        <CheckBox x:Name="StartMinimized"
                  Content="Start the app minimized"
                  Margin="0,0,0,16"
                  Click="StartMinimized_OnClick"/>
        
        <CheckBox x:Name="CheckForUpdates"
                  Content="Check for updates on startup"
                  Margin="0,0,0,16"
                  Click="CheckForUpdates_OnClick"/>

        

        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="30" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Slider x:Name="TrailingSpacesSlider"
                    Grid.Column="0"
                    Minimum="0"
                    Maximum="50"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    ValueChanged="TrailingSpacesSlider_OnValueChanged"/>

            <TextBox x:Name="TrailingSpacesTextBox"
                     Grid.Column="1"
                     Margin="10,0,0,0"
                     VerticalContentAlignment="Center"
                     HorizontalContentAlignment="Center"
                     TextChanged="TrailingSpacesTextBox_OnTextChanged"/>
            <TextBlock Grid.Column="2" Name="TrailingSpaces" Text="Amount of trailing spaces in output file"
                       Margin="10,0,0,8"/>
        </Grid>

    </StackPanel>
</Window>