<Window x:Class="CurrentlyListening.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="560"
        Height="470"
        MinWidth="470"
        MinHeight="430"
        MaxWidth="700"
        MaxHeight="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#F3F4F6">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      CornerRadius="0"
                      GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#1DB954"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#D0D5DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style x:Key="ToggleSwitchCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <Grid Width="44"
                                  Height="24"
                                  Margin="0,0,8,0">

                                <Border x:Name="SwitchBackground"
                                        CornerRadius="12"
                                        Background="#D1D5DB"
                                        BorderBrush="#9CA3AF"
                                        BorderThickness="1" />

                                <Ellipse x:Name="SwitchThumb"
                                         Width="18"
                                         Height="18"
                                         Fill="White"
                                         Margin="3"
                                         HorizontalAlignment="Left"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform x:Name="ThumbTransform" X="0" />
                                    </Ellipse.RenderTransform>

                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="4"
                                                          ShadowDepth="1"
                                                          Opacity="0.25" />
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Grid>

                            <ContentPresenter VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </StackPanel>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="SwitchBackground"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#83B540"
                                                            Duration="0:0:0.16" />

                                            <ColorAnimation Storyboard.TargetName="SwitchBackground"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#6FA031"
                                                            Duration="0:0:0.16" />

                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="20"
                                                             Duration="0:0:0.16">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>

                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="SwitchBackground"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#D1D5DB"
                                                            Duration="0:0:0.16" />

                                            <ColorAnimation Storyboard.TargetName="SwitchBackground"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#9CA3AF"
                                                            Duration="0:0:0.16" />

                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="0"
                                                             Duration="0:0:0.16">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SwitchBackground"
                                        Property="Opacity"
                                        Value="0.45" />
                                <Setter TargetName="SwitchThumb"
                                        Property="Opacity"
                                        Value="0.7" />
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom top bar -->
        <Grid Grid.Row="0"
              Background="#1F2937">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0"
                   Width="48"
                   Height="48"
                   Margin="14,0,10,0"
                   VerticalAlignment="Center"
                   Source="/Resources/icon.ico" />

            <TextBlock Grid.Column="1"
                       x:Name="WindowSettings"
                       Text="Settings"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />

            <Button Grid.Column="4"
                    Content="×"
                    Width="46"
                    Height="46"
                    Background="Transparent"
                    Foreground="#D1D5DB"
                    BorderThickness="0"
                    Click="CloseButton_Click" />
        </Grid>
        <Border Grid.Row="1" Margin="20"
                Padding="22"
                Background="White"
                CornerRadius="16"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <StackPanel>

                <TextBlock x:Name="SettingsLabel"
                           Text="Settings"
                           FontWeight="Bold"
                           FontSize="22"
                           Foreground="#111827"
                           Margin="0,0,0,18" />

                <Border Background="#F9FAFB"
                        CornerRadius="12"
                        Padding="16"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <CheckBox x:Name="CloseShouldMinimize"
                                  Content="Close window should minimize the app"
                                  Click="CloseShouldMinimize_OnClick"
                                  Style="{StaticResource ToggleSwitchCheckBoxStyle}"
                                  Margin="0,0,0, 16" />

                        <CheckBox x:Name="StartMinimized"
                                  Content="Start the app minimized"
                                  Click="StartMinimized_OnClick"
                                  Style="{StaticResource ToggleSwitchCheckBoxStyle}"
                                  Margin="0,0,0,16" />

                        <CheckBox x:Name="CheckForUpdates"
                                  Content="Check for updates on startup"
                                  Click="CheckForUpdates_OnClick"
                                  Style="{StaticResource ToggleSwitchCheckBoxStyle}"
                                  Margin="0,0,0,16" />

                        <CheckBox x:Name="ShowPopUpOnFail"
                                  Content="Show pop-up on authentication failed"
                                  Margin="0"
                                  Click="ShowPopUpOnFail_OnClick"
                                  Style="{StaticResource ToggleSwitchCheckBoxStyle}" />
                    </StackPanel>
                </Border>

                <Border Background="#F9FAFB"
                        CornerRadius="12"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Name="TrailingSpaces"
                                   Text="Amount of trailing spaces in output file"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"
                                   Margin="0,0,0,12" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>

                            <Slider x:Name="TrailingSpacesSlider"
                                    Grid.Column="0"
                                    Minimum="0"
                                    Maximum="50"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"
                                    ValueChanged="TrailingSpacesSlider_OnValueChanged" />

                            <TextBox x:Name="TrailingSpacesTextBox"
                                     Grid.Column="1"
                                     Margin="12,0,0,0"
                                     VerticalContentAlignment="Center"
                                     HorizontalContentAlignment="Center"
                                     TextChanged="TrailingSpacesTextBox_OnTextChanged" />
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>
    </Grid>
</Window>