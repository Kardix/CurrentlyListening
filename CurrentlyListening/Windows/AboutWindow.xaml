<Window x:Class="CurrentlyListening.Windows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About"
        Width="460"
        Height="310"
        MinWidth="420"
        MinHeight="260"
        MaxWidth="650"
        MaxHeight="420"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="#F3F4F6">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      CornerRadius="0"
                      GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style TargetType="Hyperlink">
            <Setter Property="Foreground" Value="#1DB954" />
            <Setter Property="TextDecorations" Value="None" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom top bar -->
        <Grid Grid.Row="0"
              Background="#1F2937">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>


            <Image Grid.Column="0"
                   Width="48"
                   Height="48"
                   Margin="14,0,10,0"
                   VerticalAlignment="Center"
                   Source="/Resources/icon.ico" />


            <TextBlock Grid.Column="1"
                       Text="CurrentlyListening"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />

            <Button Grid.Column="4"
                    Content="×"
                    Width="46"
                    Height="46"
                    Background="Transparent"
                    Foreground="#D1D5DB"
                    BorderThickness="0"
                    Click="CloseButton_Click" />
        </Grid>

        <Border Grid.Row="1" Margin="20"
                Padding="22"
                Background="White"
                CornerRadius="16"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="CurrentlyListening"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#111827" />

                    <TextBlock Text="Tom &#x00AB;TKoNoR&#x00BB;"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#6B7280"
                               Margin="0,4,0,0" />
                </StackPanel>

                <Border Grid.Row="2"
                        Background="#F9FAFB"
                        CornerRadius="12"
                        Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Email:"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"
                                   VerticalAlignment="Center" />

                        <TextBlock Grid.Row="0"
                                   Grid.Column="1"
                                   TextWrapping="Wrap">
                            <Hyperlink NavigateUri="mailto:tkonorgaming@gmail.com"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                tkonorgaming@gmail.com
                            </Hyperlink>
                        </TextBlock>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Text="Twitch:"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"
                                   VerticalAlignment="Center" />

                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   TextWrapping="Wrap">
                            <Hyperlink NavigateUri="https://twitch.tv/tkonor"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                https://twitch.tv/tkonor
                            </Hyperlink>
                        </TextBlock>

                        <TextBlock Grid.Row="4"
                                   Grid.Column="0"
                                   Text="YouTube:"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"
                                   VerticalAlignment="Center" />

                        <TextBlock Grid.Row="4"
                                   Grid.Column="1"
                                   TextWrapping="Wrap">
                            <Hyperlink NavigateUri="https://www.youtube.com/@TKoNoR"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                https://www.youtube.com/@TKoNoR
                            </Hyperlink>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>