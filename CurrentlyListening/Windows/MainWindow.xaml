<Window x:Class="CurrentlyListening.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="Window"
        Title="CurrentlyListening by TKoNoR"
        Width="720"
        Height="500"
        MinWidth="620"
        MinHeight="460"
        MaxWidth="900"
        MaxHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#F3F4F6">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      CornerRadius="0"
                      GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="ToggleSwitchCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <Grid Width="44"
                                  Height="24"
                                  Margin="0,0,8,0">

                                <Border x:Name="SwitchBackground"
                                        CornerRadius="12"
                                        Background="#D1D5DB"
                                        BorderBrush="#9CA3AF"
                                        BorderThickness="1" />

                                <Ellipse x:Name="SwitchThumb"
                                         Width="18"
                                         Height="18"
                                         Fill="White"
                                         Margin="3"
                                         HorizontalAlignment="Left"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform x:Name="ThumbTransform" X="0" />
                                    </Ellipse.RenderTransform>

                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="4"
                                                          ShadowDepth="1"
                                                          Opacity="0.25" />
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Grid>

                            <ContentPresenter VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </StackPanel>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="SwitchBackground"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#83B540"
                                                            Duration="0:0:0.16" />

                                            <ColorAnimation Storyboard.TargetName="SwitchBackground"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#6FA031"
                                                            Duration="0:0:0.16" />

                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="20"
                                                             Duration="0:0:0.16">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>

                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="SwitchBackground"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#D1D5DB"
                                                            Duration="0:0:0.16" />

                                            <ColorAnimation Storyboard.TargetName="SwitchBackground"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#9CA3AF"
                                                            Duration="0:0:0.16" />

                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="0"
                                                             Duration="0:0:0.16">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SwitchBackground"
                                        Property="Opacity"
                                        Value="0.45" />
                                <Setter TargetName="SwitchThumb"
                                        Property="Opacity"
                                        Value="0.7" />
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
                    <Setter Property="Height" Value="34"/>
                    <Setter Property="Padding" Value="14,0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Background" Value="#1DB954"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
        
                <Style TargetType="TextBox">
                    <Setter Property="Height" Value="34"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="BorderBrush" Value="#D0D5DD"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Background" Value="White"/>
                </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom top bar -->
        <Grid Grid.Row="0"
              Background="#111827"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0"
                   Width="48"
                   Height="48"
                   Margin="14,0,10,0"
                   VerticalAlignment="Center"
                   Source="/Resources/icon.ico" />

            <TextBlock Grid.Column="1"
                       Text="CurrentlyListening"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />

            <Button Grid.Column="2"
                    Content="—"
                    Width="46"
                    Height="46"
                    Background="Transparent"
                    Foreground="#D1D5DB"
                    BorderThickness="0"
                    Click="MinimizeButton_Click" />

            <Button Grid.Column="3"
                    Content="□"
                    Width="46"
                    Height="46"
                    Background="Transparent"
                    Foreground="#D1D5DB"
                    BorderThickness="0"
                    Click="MaximizeButton_Click" />

            <Button Grid.Column="4"
                    Content="×"
                    Width="46"
                    Height="46"
                    Background="Transparent"
                    Foreground="#D1D5DB"
                    BorderThickness="0"
                    Click="CloseButton_Click" />
        </Grid>

        <!-- Main content -->
        <Border Grid.Row="1"
                Margin="20"
                Padding="24"
                Background="White"
                CornerRadius="16"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <StackPanel>
                <Grid Margin="0,0,0,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CurrentlyListening"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="#111827" />

                        <TextBlock x:Name="TrackDisplay"
                                   Text="Track Display Options:"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="#6B7280"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <ComboBox x:Name="LanguageSelector"
                              Grid.Column="1"
                              Width="160"
                              Height="30"
                              VerticalAlignment="Top"
                              SelectionChanged="LanguageSelector_SelectionChanged">
                        <ComboBoxItem Tag="en" Content="English" />
                        <ComboBoxItem Tag="fr" Content="Français" />
                        <ComboBoxItem Tag="es" Content="Español" />
                        <ComboBoxItem Tag="de" Content="Deutsch" />
                        <ComboBoxItem Tag="cs" Content="Čeština" />
                        <ComboBoxItem Tag="pt" Content="Português" />
                        <ComboBoxItem Tag="uk" Content="Українська" />
                        <ComboBoxItem Tag="pl" Content="Polski" />
                    </ComboBox>
                </Grid>

                <Border Background="#F9FAFB"
                        CornerRadius="12"
                        Padding="16"
                        Margin="0,0,0,14">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="ArtistCheckbox"
                                  Content="Artist"
                                  IsChecked="True"
                                  Margin="0,0,16,0"
                                  Click="ArtistCheckbox_OnClick"
                                  Style="{StaticResource ToggleSwitchCheckBoxStyle}" />

                        <CheckBox x:Name="TitleCheckbox"
                                  Content="Song Title"
                                  IsChecked="True"
                                  Margin="0,0,16,0"
                                  Click="TitleCheckbox_OnClick"
                                  Style="{StaticResource ToggleSwitchCheckBoxStyle}" />

                        <CheckBox x:Name="DurationCheckbox"
                                  Content="Time (Progress/Duration)"
                                  IsChecked="True"
                                  Click="DurationCheckbox_OnClick"
                                  Style="{StaticResource ToggleSwitchCheckBoxStyle}" />
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="OutputPreview"
                               Text="Output preview:"
                               FontWeight="Bold"
                               FontSize="13"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Foreground="#374151" />

                    <Button x:Name="Settings"
                            Content="Settings"
                            Grid.Column="1"
                            Width="120"
                            Margin="10,0,0,0"
                            Click="OpenSettings_Click" />

                    <Button x:Name="HelpButton"
                            Content="Help"
                            Grid.Column="2"
                            Width="90"
                            Margin="10,0,0,0"
                            Click="HelpButton_Click" />
                </Grid>

                <TextBox x:Name="OutputBox"
                         IsReadOnly="True"
                         FontSize="14"
                         Height="44"
                         Margin="0,0,0,16" />

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="UpdateDisplay"
                            Content="Update Display"
                            Grid.Column="0"
                            Margin="0,0,6,0"
                            Click="UpdateDisplay_Click" />

                    <Button x:Name="LoginToSpotify"
                            Content="Login to Spotify"
                            Grid.Column="1"
                            Margin="6,0,6,0"
                            Click="LoginButton_Click" />

                    <Button x:Name="OutputFileLocation"
                            Content="Set Output File Location"
                            Grid.Column="2"
                            Margin="6,0,0,0"
                            Click="SetOutputFileButton_Click" />
                </Grid>

                <CheckBox x:Name="UseCustomCredentialsCheckbox"
                          Content="Use custom Client ID and Secret"
                          Margin="0,0,0,10"
                          Checked="UseCustomCredentialsCheckbox_Checked"
                          Unchecked="UseCustomCredentialsCheckbox_Unchecked" />

                <StackPanel x:Name="CustomCredentialsPanel"
                            Orientation="Vertical"
                            Margin="0,5,0,0"
                            Visibility="Collapsed">
                    <Grid Margin="0,0,0,5">
                        <TextBox x:Name="ClientIdTextBox"
                                 VerticalContentAlignment="Center"
                                 Padding="8,4" />

                        <TextBlock x:Name="ClientIdText"
                                   Text="Client ID"
                                   Margin="9,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#9CA3AF"
                                   IsHitTestVisible="False"
                                   Visibility="{Binding Text.IsEmpty, ElementName=ClientIdTextBox, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>

                    <Grid>
                        <TextBox x:Name="ClientSecretTextBox"
                                 VerticalContentAlignment="Center"
                                 Padding="8,4" />

                        <TextBlock x:Name="ClientSecretText"
                                   Text="Client Secret"
                                   Margin="9,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#9CA3AF"
                                   IsHitTestVisible="False"
                                   Visibility="{Binding Text.IsEmpty, ElementName=ClientSecretTextBox, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>
                </StackPanel>

                <Label HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,10,0,0">
                    <TextBlock>
                        <Run x:Name="CreatedBy" Text="Created by " />
                        <Hyperlink Click="ShowAboutWindow_Click">Tom "TKoNoR"</Hyperlink>
                    </TextBlock>
                </Label>
            </StackPanel>
        </Border>
    </Grid>
</Window>