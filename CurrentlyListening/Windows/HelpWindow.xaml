<Window x:Class="CurrentlyListening.Windows.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:CurrentlyListening.Resources"
        Title="How to Use"
        Height="520"
        Width="640"
        ResizeMode="CanResize"
        MinHeight="510"
        MinWidth="520"
        MaxHeight="550"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="#F3F4F6">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      CornerRadius="0"
                      GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Cursor" Value="IBeam" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="Hyperlink">
            <Setter Property="Foreground" Value="#1DB954" />
            <Setter Property="TextDecorations" Value="None" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom top bar -->
        <Grid Grid.Row="0"
              Background="#1F2937">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0"
                   Width="48"
                   Height="48"
                   Margin="14,0,10,0"
                   VerticalAlignment="Center"
                   Source="/Resources/icon.ico" />

            <TextBlock Grid.Column="1"
                       x:Name="TopBar"
                       Text="CurrentlyListening"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />


            <Button Grid.Column="4"
                    Content="×"
                    Width="46"
                    Height="46"
                    Background="Transparent"
                    Foreground="#D1D5DB"
                    BorderThickness="0"
                    Click="CloseButton_Click" />
        </Grid>
        <Border Grid.Row="1" Margin="20"
                Padding="22"
                Background="White"
                CornerRadius="16"
                BorderBrush="#E5E7EB"
                BorderThickness="1">


            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock x:Name="HowToUse"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#111827"
                               Margin="0,0,0,16" />

                    <Border Background="#F9FAFB"
                            CornerRadius="12"
                            Padding="16"
                            Margin="0,0,0,12">
                        <RichTextBox x:Name="Help1"
                                     IsReadOnly="True"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="0"
                                     Cursor="IBeam"
                                     FocusVisualStyle="{x:Null}">
                            <FlowDocument PagePadding="0"
                                          FontSize="13"
                                          Foreground="#374151">
                                <Paragraph x:Name="ClickableURL" />
                            </FlowDocument>
                        </RichTextBox>
                    </Border>

                    <Border Background="#F9FAFB"
                            CornerRadius="12"
                            Padding="16"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBox x:Name="Help2"
                                     IsReadOnly="True"
                                     Margin="0,0,0,8" />

                            <TextBox x:Name="Help3"
                                     IsReadOnly="True"
                                     Margin="0,0,0,8" />

                            <TextBox x:Name="Help4"
                                     IsReadOnly="True"
                                     Margin="0,0,0,8" />

                            <TextBox x:Name="Help5"
                                     IsReadOnly="True" />
                        </StackPanel>
                    </Border>

                    <Border Background="#ECFDF5"
                            BorderBrush="#BBF7D0"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14">
                        <TextBlock x:Name="HelpTip"
                                   TextWrapping="Wrap"
                                   FontStyle="Italic"
                                   Foreground="#166534" />
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>