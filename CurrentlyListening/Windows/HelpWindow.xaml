<Window x:Class="CurrentlyListening.Windows.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:CurrentlyListening.Resources"
        Title="How to Use" Height="350" Width="550"
        ResizeMode="CanResize"
        MinHeight="250" MinWidth="450"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Border Background="#FFF" CornerRadius="8" Padding="15" BorderBrush="#DDD" BorderThickness="1">
            <ScrollViewer>
                <StackPanel>
                    <TextBlock x:Name="HowToUse"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <RichTextBox x:Name="Help1" Margin="0,0,0,6" IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="0"

                                 Cursor="IBeam"
                                 FocusVisualStyle="{x:Null}" >
                        <FlowDocument>
                            <Paragraph x:Name="ClickableURL"/>
                            </FlowDocument>
                    </RichTextBox>
                    
                    
                    <TextBox x:Name="Help2" IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             TextWrapping="Wrap"
                             Cursor="IBeam"
                             FocusVisualStyle="{x:Null}" Margin="0,0,0,6"></TextBox>
                    
                    <TextBox x:Name="Help3" IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             TextWrapping="Wrap"
                             Cursor="IBeam"
                             FocusVisualStyle="{x:Null}" Margin="0,0,0,6"></TextBox>
                    
                    <TextBox x:Name="Help4" IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             TextWrapping="Wrap"
                             Cursor="IBeam"
                             FocusVisualStyle="{x:Null}"  Margin="0,0,0,6"></TextBox>
                    
                    <TextBox x:Name="Help5" IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             TextWrapping="Wrap"
                             Cursor="IBeam"
                             FocusVisualStyle="{x:Null}" Margin="0,0,0,6"></TextBox>
                    
                    <TextBlock x:Name="HelpTip" TextWrapping="Wrap" Margin="0,10,0,0" FontStyle="Italic" Foreground="Gray"></TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
